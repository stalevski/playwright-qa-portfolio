{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "@playwright/test"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@config": ["./test-targets.config.ts"],
      "@core/*": ["./src/core/*"],
      "@pages/*": ["./src/pages/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@fixtures/*": ["./src/fixtures/*"],
      "@swagger-petstore-fixtures": ["./src/fixtures/swagger-petstore/index.ts"],
      "@pethub-local-fixtures": ["./src/fixtures/pethub-local/index.ts"],
      "@sauce-demo-fixtures": ["./src/fixtures/sauce-demo/index.ts"],
      "@data/*": ["./src/test-data/*"],
      "@models/*": ["./src/models/*"],
      "@builders/*": ["./src/builders/*"]
    }
  },
  "include": ["playwright.config.ts", "test-targets.config.ts", "src/**/*.ts", "tests/**/*.ts", "apps/**/*.ts"]
}
