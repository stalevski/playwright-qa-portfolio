{
  "name": "playwright-qa-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "app:start": "tsx apps/pethub-local/server.ts",
    "stop": "tsx scripts/stop-app.ts",
    "test": "npm run test:external && npm run test:local",
    "test:external": "playwright test",
    "test:local": "playwright test --config playwright.local.config.ts",
    "test:swagger-petstore": "playwright test --project=swagger-petstore-ui-chromium --project=swagger-petstore-ui-firefox --project=swagger-petstore-ui-webkit --project=swagger-petstore-api",
    "test:swagger-petstore:ui": "playwright test --project=swagger-petstore-ui-chromium --project=swagger-petstore-ui-firefox --project=swagger-petstore-ui-webkit",
    "test:swagger-petstore:api": "playwright test --project=swagger-petstore-api",
    "test:sauce-demo": "playwright test --project=sauce-demo-ui-chromium --project=sauce-demo-ui-firefox --project=sauce-demo-ui-webkit",
    "test:sauce-demo:ui": "playwright test --project=sauce-demo-ui-chromium --project=sauce-demo-ui-firefox --project=sauce-demo-ui-webkit",
    "test:pethub-local": "playwright test --config playwright.local.config.ts",
    "test:pethub-local:ui": "playwright test --config playwright.local.config.ts --project=pethub-local-ui-chromium --project=pethub-local-ui-firefox --project=pethub-local-ui-webkit",
    "test:pethub-local:api": "playwright test --config playwright.local.config.ts --project=pethub-local-api",
    "test:ui": "playwright test tests/external/swagger-petstore/ui tests/external/sauce-demo/ui && playwright test --config playwright.local.config.ts tests/local/pethub-local/ui",
    "test:api": "playwright test tests/external/swagger-petstore/api && playwright test --config playwright.local.config.ts tests/local/pethub-local/api",
    "test:smoke": "playwright test --grep @smoke && playwright test --config playwright.local.config.ts --grep @smoke",
    "test:critical": "playwright test --grep @critical && playwright test --config playwright.local.config.ts --grep @critical",
    "test:a11y": "playwright test --config playwright.local.config.ts --project=pethub-local-a11y",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "report:local": "playwright show-report playwright-report-local",
    "docs:pdf": "tsx scripts/md-to-pdf.ts docs/sauce-demo/bugs.md",
    "docs:pdf:petstore": "tsx scripts/md-to-pdf.ts docs/swagger-petstore/bugs.md",
    "docs:pdf:all": "npm run docs:pdf && npm run docs:pdf:petstore",
    "screenshots": "tsx scripts/capture-screenshots.ts",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "doctor": "node --version && npm --version && npx playwright --version && npx tsc --noEmit && echo Doctor: OK"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "lowdb": "^7.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/express": "^5.0.6",
    "@types/marked": "^5.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.4",
    "globals": "^17.6.0",
    "marked": "^18.0.5",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
